APP_NAME=RustFS

# Description
APP_DESCRIPTION="RustFS is a distributed file system written in Rust."

# Admin API base URL
API_BASE_URL=http://localhost:9000/rustfs/admin/v3

# Console base URL
BASE_URL=/rustfs/console/

# S3 API base URL
S3_ENDPOINT=http://localhost:9000

# Grafana dashboard
GRAFANA_URL=http://172.24.37.159:23000
GRAFANA_DASHBOARD_ID=rustfs-s3
GRAFANA_DASHBOARD_SLUG=rustfs
GRAFANA_REFRESH=15s
GRAFANA_TIME_RANGE=now-1h

# GPUStack management API base URL
# Example: http://localhost:8000/v2
GPUSTACK_API_URL=http://localhost:8000/v2
GPUSTACK_API_KEY=
# Optional: comma-separated model names that LakeToken is allowed to modify.
# Example for production safety: qwen3-14b
GPUSTACK_ALLOWED_MODEL_NAMES=

# default region
S3_REGION=us-east-1

# Version
VERSION=1.0.0-alpha.70

# Volume Catalog (PostgreSQL)
VOLUME_CATALOG_DB_HOST=localhost
VOLUME_CATALOG_DB_PORT=5432
VOLUME_CATALOG_DB_USER=postgres
VOLUME_CATALOG_DB_PASSWORD=postgres
VOLUME_CATALOG_DB_NAME=object_metadata
VOLUME_CATALOG_DB_SCHEMA=public
VOLUME_CATALOG_DB_TABLE=object_table

# NFS Directory Management
# IP/hostname of the NFS server; used to reach nfs-agent (port 18081) and to compose NFS mount sources
NFS_EXPORT_HOST=172.24.37.159
# Note: nfs-agent URL is derived automatically as http://{NFS_EXPORT_HOST}:18081
# Note: mount-agent URL is derived automatically as http://{user-entered host}:18082
# Note: NFS_SHARED_PATH and NFS_EXPORT_HOST are configured separately in nfs-agent.env on the NFS server
