# GPUStack API endpoint, without a trailing slash.
GPUSTACK_API_URL=https://gpustack.example.com/api

# GPUStack API key sent as X-API-Key.
GPUSTACK_API_KEY=replace-me

# Agent listen address.
PROMETHEUS_VLLM_SD_HOST=0.0.0.0
PROMETHEUS_VLLM_SD_PORT=18083

# Optional allowlist of model names, comma-separated.
GPUSTACK_ALLOWED_MODEL_NAMES=

# GPUStack request timeout in seconds.
TARGET_REQUEST_TIMEOUT_SECONDS=10

# Fallback metrics port if the instance payload does not provide one.
TARGET_DEFAULT_METRICS_PORT=8000

# Candidate instance fields used to resolve the target host and port.
TARGET_HOST_FIELD_CANDIDATES=metrics_host,worker_ip,ip,host
TARGET_PORT_FIELD_CANDIDATES=metrics_port,port